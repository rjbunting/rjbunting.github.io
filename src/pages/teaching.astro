---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title="Teaching Philosophy" sideBarActiveItemID="teaching">
    <!-- Hero / summary with profile image -->
    <section class="bg-base-200 text-base-content rounded-lg p-6 mb-8 flex flex-col md:flex-row items-center gap-6 no-hover-scale">
        <div class="flex-1">
            <h1 class="text-3xl w-full font-bold mb-3">Teaching Philosophy</h1>
            <p class="text-lg mb-4 opacity-95">
                My teaching philosophy emphasizes fostering an environment conducive of learning.
                Teaching goes beyond course material, with a need for soft skills to be taught and developed within students.
                My role as an educator is to spark passions and enable students to reach their full potential.
                It is crucial for teaching to be adapted and tailored for all students on an individual basis.
                This should be created through an environment that caters to both inclusivity and diversity.
            </p>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-sm">
                <li class="bg-base-100/60 rounded px-3 py-2">
                    <div class="font-semibold">Direct instruction for base knowledge</div>
                </li>
                <li class="bg-base-100/60 rounded px-3 py-2">
                    <div class="font-semibold">Case studies to grow intellectual curiosity</div>
                </li>
                <li class="bg-base-100/60 rounded px-3 py-2">
                    <div class="font-semibold">Flipped-classroom workshops</div>
                </li>
                <li class="bg-base-100/60 rounded px-3 py-2">
                    <div class="font-semibold">Open and accessible course materials</div>
                </li>
            </ul>
        </div>
    </section>

    <!-- Teaching highlights / metrics (animated counters) -->
    <section class="mb-8 reveal px-6">
        <!--<h2 class="text-2xl font-bold mb-4">Teaching Highlights</h2>-->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div class="bg-base-100 rounded-lg p-4 shadow border-l-4 border-primary cursor-pointer">
                <div class="text-3xl font-bold"><span class="counter" data-target="6" data-duration="900">0</span></div>
                <div class="text-sm text-muted">Years teaching experience</div>
            </div>
            <div class="bg-base-100 rounded-lg p-4 shadow border-l-4 border-secondary cursor-pointer">
                <div class="text-3xl font-bold"><span class="counter" data-target="1000+" data-duration="1200">0</span></div>
                <div class="text-sm text-muted">Students taught (lectures & workshops)</div>
            </div>
            <div class="bg-base-100 rounded-lg p-4 shadow border-l-4 border-accent cursor-pointer">
                <div class="text-3xl font-bold"><span class="counter" data-target="3" data-duration="1000">0</span></div>
                <div class="text-sm text-muted">Students supervised</div>
            </div>
        </div>
    </section>

    <!-- Courses (wrapper) -->
    <section id="courses" class="mb-8 reveal px-6">
        <h2 class="text-2xl font-bold mb-3">Materials for my courses:</h2>
        <!--<p class="text-sm text-muted mb-4">A selection of courses I have designed and taught. Each course below includes materials and metadata.</p>-->

        <div class="space-y-5">
            <!-- Computational Chemistry subsection -->
            <details id="computational-chemistry" class="reveal group bg-base-100 rounded-xl shadow-lg border-2 border-base-300 hover:border-base-content/40 hover:shadow-xl transition-all duration-300 overflow-hidden">
                <summary class="flex items-center justify-between cursor-pointer px-6 py-5 list-none hover:bg-base-200/60 transition-all duration-200 select-none">
                    <span class="flex items-center gap-4">
                        <span class="shrink-0 w-12 h-12 rounded-xl bg-base-200 border border-base-300 flex items-center justify-center text-base-content shadow-sm group-hover:scale-110 transition-transform duration-200 p-2">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 -2 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full">
                                <!-- Laptop screen -->
                                <rect x="2" y="2" width="20" height="13" rx="1.5"/>
                                <!-- Laptop base -->
                                <path d="M1 15H23L21.5 18H2.5Z"/>
                                <!-- Erlenmeyer flask on screen: top of neck → right neck → right body → base → left body → left neck (Z) -->
                                <path d="M10.5 4H13.5V7L16 13H8L10.5 7Z"/>
                                <!-- Liquid bubbles inside flask -->
                                <circle cx="11.5" cy="10.5" r="0.75" fill="currentColor" stroke="none"/>
                                <circle cx="13" cy="9.5" r="0.75" fill="currentColor" stroke="none"/>
                            </svg>
                        </span>
                        <span class="block">
                            <span class="block text-xl font-bold">An Introduction to Computational Chemistry</span>
                            <span class="block text-sm text-muted mt-1">Lectures and hands-on workshop series for teaching practical computational chemistry skills.</span>
                            <span class="flex items-center gap-2 flex-wrap mt-2">
                                <span class="badge badge-primary badge-sm font-medium">Lecture Slides</span>
                                <span class="badge badge-secondary badge-sm font-medium">Jupyter Notebooks</span>
                            </span>
                        </span>
                    </span>
                    <span class="ml-4 shrink-0 w-9 h-9 rounded-full bg-base-200 border border-base-300 text-base-content flex items-center justify-center transition-transform duration-300 group-open:rotate-180 group-open:bg-base-300">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                        </svg>
                    </span>
                </summary>

                <div class="px-5 pb-5 pt-2 border-t-2 border-base-200">
                    <div class="grid gap-3 mb-4 md:grid-cols-2 mt-4">
                        <div class="bg-base-200 rounded-lg p-4">
                            <div class="font-semibold">Role</div>
                            <div class="text-sm text-muted">Course author, lecturer, and workshop instructor</div>
                            <div class="mt-2 font-semibold">Level</div>
                            <div class="text-sm text-muted">Undergraduate</div>
                            <div class="mt-2 font-semibold">Format</div>
                            <div class="text-sm text-muted">Lectures + Jupyter-based workshops</div>
                        </div>
                        <div class="bg-base-200 rounded-lg p-4">
                            <div class="font-semibold">Responsibilities</div>
                            <ul class="list-disc pl-5 text-sm text-muted mt-1">
                                <li>Designing syllabus, learning outcomes and assessments</li>
                                <li>Developing Jupyter notebooks and workshop materials</li>
                                <li>Delivering lectures and supervising students</li>
                            </ul>
                        </div>
                    </div>

                    <HorizontalCard
                        title="Introduction to Computational Chemistry Workshops"
                        img="/images/h2.png"
                        desc="Jupyter Notebooks and reproducible workflows for workshops."
                        url="https://github.com/rjbunting/introcompchemnotebooks"
                        disableHover={true}
                    />

                    <!-- Launch badges for interactive notebooks -->
                    <div class="mt-3 mb-4 flex items-center gap-3">
                        <a href="https://colab.research.google.com/github/rjbunting/introcompchemnotebooks" target="_blank" class="btn btn-sm btn-outline">Open in Colab</a>
                        <a href="https://github.com/rjbunting/introcompchemnotebooks" target="_blank" class="btn btn-sm">View on GitHub</a>
                    </div>

                    <HorizontalCard
                        title="Lecture Slides"
                        img="/images/chemistryslides.png"
                        desc="Lecture slides for 'An Introduction to Computational Chemistry', covering computing, empirical methods, ab initio methods, molecular modeling, and kinetics and thermodynamics."
                        url="https://1drv.ms/p/s!AgEBZympJpEbhQFu2u64HWlnLAQI"
                        disableHover={true}
                    />
                </div>
            </details>

            <!-- Catalysis subsection -->
            <details id="catalysis" class="reveal group bg-base-100 rounded-xl shadow-lg border-2 border-base-300 hover:border-base-content/40 hover:shadow-xl transition-all duration-300 overflow-hidden">
                <summary class="flex items-center justify-between cursor-pointer px-6 py-5 list-none hover:bg-base-200/60 transition-all duration-200 select-none">
                    <span class="flex items-center gap-4">
                        <span class="shrink-0 w-12 h-12 rounded-xl bg-base-200 border border-base-300 flex items-center justify-center text-base-content shadow-sm group-hover:scale-110 transition-transform duration-200 p-2">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="6 6 12 12" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full">
                                <!-- Radial bonds: center to ring -->
                                <line x1="12" y1="12" x2="16" y2="12"/>
                                <line x1="12" y1="12" x2="14" y2="8.5"/>
                                <line x1="12" y1="12" x2="10" y2="8.5"/>
                                <line x1="12" y1="12" x2="8" y2="12"/>
                                <line x1="12" y1="12" x2="10" y2="15.5"/>
                                <line x1="12" y1="12" x2="14" y2="15.5"/>
                                <!-- Ring bonds -->
                                <line x1="16" y1="12" x2="14" y2="8.5"/>
                                <line x1="14" y1="8.5" x2="10" y2="8.5"/>
                                <line x1="10" y1="8.5" x2="8" y2="12"/>
                                <line x1="8" y1="12" x2="10" y2="15.5"/>
                                <line x1="10" y1="15.5" x2="14" y2="15.5"/>
                                <line x1="14" y1="15.5" x2="16" y2="12"/>
                                <!-- Atoms (drawn on top of bonds) -->
                                <circle cx="12" cy="12" r="2" fill="currentColor" stroke="none"/>
                                <circle cx="16" cy="12" r="1.4" fill="currentColor" stroke="none"/>
                                <circle cx="14" cy="8.5" r="1.4" fill="currentColor" stroke="none"/>
                                <circle cx="10" cy="8.5" r="1.4" fill="currentColor" stroke="none"/>
                                <circle cx="8" cy="12" r="1.4" fill="currentColor" stroke="none"/>
                                <circle cx="10" cy="15.5" r="1.4" fill="currentColor" stroke="none"/>
                                <circle cx="14" cy="15.5" r="1.4" fill="currentColor" stroke="none"/>
                            </svg>
                        </span>
                        <span class="block">
                            <span class="block text-xl font-bold">An Introduction to Catalysis</span>
                            <span class="block text-sm text-muted mt-1">Course covers catalytic mechanisms, kinetics, and practical examples.</span>
                            <span class="flex items-center gap-2 flex-wrap mt-2">
                                <span class="badge badge-primary badge-sm font-medium">Lecture Slides</span>
                            </span>
                        </span>
                    </span>
                    <span class="ml-4 shrink-0 w-9 h-9 rounded-full bg-base-200 border border-base-300 text-base-content flex items-center justify-center transition-transform duration-300 group-open:rotate-180 group-open:bg-base-300">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                        </svg>
                    </span>
                </summary>

                <div class="px-5 pb-5 pt-2 border-t-2 border-base-200">
                    <div class="grid gap-3 mb-4 md:grid-cols-2 mt-4">
                        <div class="bg-base-200 rounded-lg p-4">
                            <div class="font-semibold">Role</div>
                            <div class="text-sm text-muted">Course author and lecturer</div>
                            <div class="mt-2 font-semibold">Level</div>
                            <div class="text-sm text-muted">Advanced undergraduate</div>
                            <div class="mt-2 font-semibold">Format</div>
                            <div class="text-sm text-muted">Lectures and problem sets</div>
                        </div>
                        <div class="bg-base-200 rounded-lg p-4">
                            <div class="font-semibold">Responsibilities</div>
                            <ul class="list-disc pl-5 text-sm text-muted mt-1">
                                <li>Writing lecture materials and practical case studies</li>
                                <li>Designing assessments to build research-relevant skills</li>
                                <li>Deliver lectures</li>
                                <li>Marking and giving feedback on assignments</li>
                            </ul>
                        </div>
                    </div>

                    <HorizontalCard
                        title="Lecture Slides"
                        img="/images/catalysisslides.png"
                        desc="Lecture slides for 'An Introduction to Catalysis' course covering reaction mechanisms, kinetics, and computational perspectives."
                        url="https://1drv.ms/p/s!AgEBZympJpEbhFlHNu-2NOqKiCCc"
                        disableHover={true}
                    />
                </div>
            </details>
        </div>
    </section>


    <section class="bg-base-200 p-6 rounded-lg shadow mb-8 flex flex-col md:flex-row items-center gap-6">
        <div class="flex-1 text-center">
            <blockquote class="lg">"The task of the modern educator is not to cut down jungles, but to irrigate deserts."</blockquote>
            <div class="mt-3 text-sm text-muted">C.S. Lewis</div>
        </div>
    </section>

</BaseLayout>
